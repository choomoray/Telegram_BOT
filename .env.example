# =============================================================================
# Telegram 媒体管理机器人 - 环境变量配置模板
# =============================================================================
# 使用方式：
#   1. 复制此文件为 .env：   cp .env.example .env
#   2. 将占位值替换为你自己的配置
#   3. 启动机器人：           node index.js
#
# 必填项标记为 [必填]，其余为可选（已提供默认值）
# =============================================================================


# -----------------------------------------------------------------------------
# Telegram Bot Token [必填]
# -----------------------------------------------------------------------------
# 从 @BotFather (https://t.me/BotFather) 创建 Bot 后获取
# 格式：数字:字母数字组合
TELEGRAM_BOT_TOKEN=你的_Bot_Token


# -----------------------------------------------------------------------------
# MongoDB Atlas 连接串 [必填]
# -----------------------------------------------------------------------------
# 生产数据库 - 从 MongoDB Atlas 获取的连接串
MONGODB_URI=mongodb+srv://用户名:密码@集群地址.mongodb.net/?appName=应用名

# 测试数据库 - 使用 --test 参数启动时使用此连接
# 启动方式：node index.js --test
TEST_MONGODB_URI=mongodb+srv://用户名:密码@测试集群.mongodb.net/


# -----------------------------------------------------------------------------
# 管理员用户 ID [必填]
# -----------------------------------------------------------------------------
# 拥有 Bot 完整管理权限的 Telegram 用户 ID，多个用逗号分隔
# 获取方式：向 @userinfobot 发送任意消息即可看到 Your ID
ADMIN_CHAT_ID=第一个管理员ID, 第二个管理员ID


# -----------------------------------------------------------------------------
# AI - Ollama 配置（可选）
# -----------------------------------------------------------------------------
# Ollama 本地模型 API（当前代码中实际未使用，预留）
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3.5:2b


# -----------------------------------------------------------------------------
# AI - LM Studio 配置（可选，默认用作 AI 备选模型）
# -----------------------------------------------------------------------------
# LM Studio 本地 API（需在 LM Studio 中加载模型并启动服务）
LMSTUDIO_API_URL=http://localhost:1234/v1/chat/completions
# LM Studio 中加载的模型名称
LMSTUDIO_MODEL=你的LMStudio模型名
# API 超时时间（毫秒）
LMSTUDIO_API_TIMEOUT=60000


# -----------------------------------------------------------------------------
# AI - DeepSeek API 配置（可选，默认用作 AI 主模型）
# -----------------------------------------------------------------------------
# DeepSeek API 或兼容 OpenAI 格式的本地 API
DEEPSEEK_API_URL=http://127.0.0.1:55555/v1/chat/completions
# API 密钥（使用本地 API 可填任意值如 sk-any）
DEEPSEEK_API_KEY=你的DeepSeek或OpenAI兼容API密钥
# 模型名称
DEEPSEEK_MODEL=deepseek-chat
# API 超时时间（毫秒）
DEEPSEEK_API_TIMEOUT=60000


# -----------------------------------------------------------------------------
# HTTP 连接池配置（可选）
# -----------------------------------------------------------------------------
# AI API 调用的 HTTP 连接池最大套接字数
CONNECTION_POOL_MAX_SOCKETS=10
